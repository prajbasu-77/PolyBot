# ============================================================
# POLYBOT CONFIG - KEEP THIS FILE SECRET, NEVER SHARE IT
# ============================================================

# Your Phantom wallet PRIVATE KEY (export from Phantom → Settings → Security)
PRIVATE_KEY=YOUR_PHANTOM_PRIVATE_KEY_HERE

# Your Polymarket proxy/funder address (shown on polymarket.com profile)
FUNDER_ADDRESS=YOUR_POLYMARKET_WALLET_ADDRESS_HERE

# Mode: PAPER (fake money, real signals) or LIVE (real money)
MODE=PAPER

# How much USDC to bet per trade (in dollars)
BET_SIZE=5

# Minimum edge required to place a bet (0.85 = 85% confident)
MIN_CONFIDENCE=0.85

# Polymarket API
POLY_HOST=https://clob.polymarket.com
CHAIN_ID=137
